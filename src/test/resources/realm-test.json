{
  "realm": "auth-realm",
  "enabled": true,
  "roles": {
    "realm": [
      {
        "name": "USER"
      },
      {
        "name": "ADMIN"
      }
    ]
  },
  "clientScopes": [
    {
      "name": "service.read",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "true"
      },
      "protocolMappers": []
    }
  ],
  "clients": [
    {
      "clientId": "auth-client",
      "name": "Auth Service Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "optionalClientScopes": ["service.read"],
      "protocolMappers": [
        {
          "name": "custom-attributes-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "custom_attributes",
            "claim.name": "custom_attributes",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        }
      ],
      "secret": "auth-client-secret"
    }
  ]
}
